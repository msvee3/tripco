# ── Backend ──────────────────────────────────────────────
APP_NAME="Tripco API"
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,https://tripco.oodhwe.in

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Azure Cosmos DB (use emulator locally)
COSMOS_ENDPOINT=https://travel-companion-db.documents.azure.com:443/
COSMOS_KEY=
COSMOS_DATABASE=tripco

# Azure Blob Storage (use Azurite locally)
BLOB_ACCOUNT_NAME=devstoreaccount1
BLOB_ACCOUNT_KEY=
BLOB_CONTAINER_MEDIA=media
BLOB_CONTAINER_TICKETS=tickets

# Azure Web PubSub (optional for local dev)
WEBPUBSUB_ENDPOINT=
WEBPUBSUB_KEY=
WEBPUBSUB_HUB=trips

# Currency
EXCHANGE_RATE_API=https://api.exchangerate.host/latest

# ── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-me-use-openssl-rand-base64-32

# Google OAuth (uncomment to enable)
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
